<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:minWidth="@dimen/chat_message_content_max_width"
    android:id="@+id/layoutl3">

    <TextView
        android:id="@+id/titlel3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/white"
        />
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        >
        <TextView
            android:id="@+id/timel3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            />
        <TextView
            android:id="@+id/statel3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#969696"
            android:layout_alignParentRight="true"
            />
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        >
        <com.tencent.qcloud.tuikit.tuichat.classicui.widget.RoundImageView
            android:id="@+id/iconl3"
            android:layout_width="75dp"
            android:layout_height="75dp"
            app:corner_radius="10dp"
            android:src="@mipmap/ic_default_image"
            android:scaleType="centerCrop"
            />
        <TextView
            android:id="@+id/contentl3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="9dp"
            android:layout_marginRight="9dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_toRightOf="@id/iconl3"
            />
        <TextView
            android:id="@+id/pricel3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:layout_alignBottom="@id/iconl3"
            android:textColor="#FF4646"
            android:layout_toRightOf="@id/iconl3"
            android:layout_marginLeft="9dp"
            />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="15dp"
        android:background="#585858"/>

    <TextView
        android:id="@+id/operationl3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="12sp"
        android:textColor="#EACA92"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:background="@drawable/shape_rectangle"
        />

</LinearLayout>