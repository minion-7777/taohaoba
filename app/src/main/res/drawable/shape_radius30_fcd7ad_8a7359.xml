<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. 渐变边框（模拟） -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#99ffffff"
                android:endColor="#99ffffff"
                android:type="linear" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <!-- 2. 背景色（覆盖中间部分） -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <!--            <solid android:color="#242527" />-->
            <gradient
                android:angle="180"
                android:startColor="#8A7359"
                android:endColor="#80FCD7AD"
                android:type="linear" />
            <corners android:radius="30dp" />
        </shape>
    </item>
</layer-list>