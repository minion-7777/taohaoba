<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/shape_radius10_242527">

    <TextView
        android:id="@+id/tv_title"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="17dp"
        android:text="价格区间"
        android:textSize="18sp"
        android:textColor="#FFFFFF"/>

    <LinearLayout
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:layout_constraintBottom_toTopOf="@+id/ll_bottom"
        android:paddingLeft="26dp"
        android:paddingRight="26dp"
        android:paddingTop="17dp"
        android:paddingBottom="20dp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/et_min"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginRight="10dp"
            android:gravity="center"
            android:hint="最低价格"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:maxLength="9"
            android:textColorHint="#D6D6D6"
            android:textSize="14sp"
            android:background="@drawable/shape_radius2_5_line_d6d6d6"/>

        <View
            android:id="@+id/view"
            app:layout_constraintBottom_toTopOf="@+id/ll_bottom"
            android:layout_width="40dp"
            android:layout_height="0.5dp"
            android:background="#4A4A4A"/>

        <EditText
            android:id="@+id/et_max"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginLeft="10dp"
            android:gravity="center"
            android:hint="最高价格"
            android:maxLength="9"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#D6D6D6"
            android:textSize="14sp"
            android:background="@drawable/shape_radius2_5_line_d6d6d6"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        android:paddingLeft="56dp"
        android:paddingRight="56dp"
        android:paddingTop="17dp"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_cancel"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginRight="20dp"
            android:gravity="center"
            android:text="重置"
            android:textColor="#888888"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_line_b9b9b9"/>

        <TextView
            android:id="@+id/tv_submit"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginLeft="20dp"
            android:gravity="center"
            android:text="确认"
            android:textColor="#402802"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_ffd497_fafbf5"/>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>