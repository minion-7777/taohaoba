<?xml version="1.0" encoding="utf-8"?>
<layout>

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="17dp"
        android:paddingLeft="12.5dp"
        android:paddingRight="12.5dp"
        android:background="@color/page_color">

        <FrameLayout
            android:id="@+id/fl_search"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/shape_radius18_3c3c3c">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:drawableLeft="@mipmap/ic_search"
                android:layout_marginLeft="12dp"
                android:drawablePadding="10dp"
                android:imeOptions="actionDone"
                android:maxLength="15"
                android:inputType="text"
                android:singleLine="true"
                android:hint="请输入游戏名称"
                android:textColorHint="#7B7B7B"
                android:background="@null"
                android:textColor="#7B7B7B"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_search"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:background="@drawable/shape_radius15_feeba7"
                android:paddingLeft="23dp"
                android:paddingRight="23dp"
                android:gravity="center"
                android:layout_gravity="center_vertical|right"
                android:text="搜索"
                android:textColor="#402802"
                android:textSize="13sp"/>

        </FrameLayout>

        <TextView
            android:id="@+id/tv_zhanghao"
            app:layout_constraintTop_toBottomOf="@+id/fl_search"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="账号"
            android:textColor="#FFFFFF"
            android:textSize="15sp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcGameType"
            app:layout_constraintTop_toBottomOf="@+id/tv_zhanghao"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:listitem="@layout/item_game_type"
            tools:itemCount="3"/>

        <TextView
            android:id="@+id/tv_qbyx"
            app:layout_constraintTop_toBottomOf="@+id/rcGameType"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="全部游戏"
            android:textColor="#FFFFFF"
            android:textSize="15sp"/>

        <io.openim.android.taohaoba.widgets.CustomLetterNavigationView
            android:id="@+id/tv_letterNavigationView"
            app:layout_constraintTop_toBottomOf="@+id/tv_qbyx"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="65dp"
            android:background="@drawable/shape_radius9_242527"
            app:textSize="9sp"
            app:textColor="#9B9B9B"
            app:selectedTextColor="#402802"
            app:letterSpacing="0dp"
            app:selectedBgColor="#FFD497"
            app:selectedBgRadius="45dp"
            android:layout_width="17dp"
            android:layout_height="0dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rc_recycler"
            app:layout_constraintTop_toBottomOf="@+id/tv_qbyx"
            app:layout_constraintEnd_toStartOf="@+id/tv_letterNavigationView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginRight="10dp"
            android:paddingTop="16dp"
            tools:itemCount="18"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="5"
            tools:listitem="@layout/item_game_list"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
