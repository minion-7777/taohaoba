<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginStart="10dp"
        android:textColor="@color/white"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_recycler1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:paddingTop="5dp">

        <TextView
            android:id="@+id/tv_SelectAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="全选"
            android:drawableStart="@mipmap/ic_check_f"
            android:drawablePadding="8dp"
            android:textSize="14sp"
            android:textColor="#989898"/>

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioButton1"
                android:layout_width="wrap_content"
                android:layout_height="23dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:button="@null"
                android:background="@drawable/selector_radiobutton1"
                android:checked="true"
                android:text="全都要有"
                android:tag="and"
                android:textColor="@drawable/selector_radiobutton_text_color1"
                android:textSize="13sp"/>

            <RadioButton
                android:id="@+id/radioButton2"
                android:layout_width="wrap_content"
                android:layout_height="23dp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:button="@null"
                android:background="@drawable/selector_radiobutton1"
                android:text="有1个就行"
                android:tag="or"
                android:textColor="@drawable/selector_radiobutton_text_color1"
                android:textSize="13sp"/>

        </RadioGroup>

    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_recycler2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="5dp"/>

    <TextView
        android:id="@+id/tv_expand2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="展开"
        android:textColor="@color/color_EACA92"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"/>

</LinearLayout>