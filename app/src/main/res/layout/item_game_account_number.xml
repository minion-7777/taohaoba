<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginBottom="12dp"
    android:padding="15dp"
    android:background="@drawable/shape_radius10_1e1e1e_a7a7a7"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <io.openim.android.taohaoba.widgets.RoundImageView
        android:id="@+id/iv_img"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:scaleType="centerCrop"
        android:layout_height="180dp"
        app:corner_radius="10dp"
        android:src="@mipmap/ic_default_image"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_recycler"
        app:layout_constraintTop_toBottomOf="@+id/iv_img"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:listitem="@layout/item_tag"
        tools:itemCount="2"/>

    <TextView
        android:id="@+id/tv_view_count"
        app:layout_constraintTop_toBottomOf="@+id/iv_img"
        app:layout_constraintEnd_toStartOf="@+id/tv_give_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginStart="5dp"
        android:drawableLeft="@mipmap/ic_view_f"
        android:drawablePadding="5dp"
        android:layout_marginTop="11dp"
        android:text="0"
        android:textColor="#969696"
        android:textSize="11sp"/>

    <TextView
        android:id="@+id/tv_give_up"
        app:layout_constraintTop_toBottomOf="@+id/iv_img"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="11dp"
        android:drawableLeft="@mipmap/ic_give_up_f"
        android:drawablePadding="5dp"
        android:text="0"
        android:textColor="#969696"
        android:textSize="11sp"/>

    <TextView
        android:id="@+id/tv_hint"
        app:layout_constraintTop_toBottomOf="@+id/rc_recycler"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#FFFFFF"
        android:textSize="14sp"/>

    <RelativeLayout
        app:layout_constraintTop_toBottomOf="@+id/tv_hint"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12.5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

<!--        <io.openim.android.taohaoba.widgets.CircleImageView-->
<!--            android:id="@+id/iv_head"-->
<!--            android:layout_width="25dp"-->
<!--            android:layout_height="25dp"-->
<!--            android:scaleType="centerCrop"-->
<!--            android:src="@mipmap/ic_profile_picture"/>-->

<!--        <TextView-->
<!--            android:id="@+id/tv_name"-->
<!--            android:layout_toRightOf="@+id/iv_head"-->
<!--            android:layout_centerVertical="true"-->
<!--            android:layout_marginLeft="10dp"-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:text="夏天的风"-->
<!--            android:textColor="#969696"-->
<!--            android:textSize="11sp"/>-->

        <TextView
            android:id="@+id/tv_time"
            android:layout_centerVertical="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:text="3分钟前发布"
            android:textColor="#969696"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/tv_price"
            android:layout_centerVertical="true"
            android:layout_alignParentRight="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="￥0.00"
            android:textColor="#FF4646"
            android:textSize="18sp"/>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>