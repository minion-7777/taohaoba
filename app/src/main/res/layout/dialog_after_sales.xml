<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/shape_semicircle_radius10_242527">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="15dp"
            android:text="请选择售后类型"
            android:textColor="#ffffff"
            android:textSize="18sp"/>

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="19dp"
            android:layout_gravity="right"
            android:src="@mipmap/ic_close"/>

    </FrameLayout>

    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="19dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp">

        <RadioButton
            android:id="@+id/radioButton1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/selector_checkbox_selector"
            android:button="@null"
            android:background="@null"
            android:tag="1"
            android:text="实名问题"
            android:textColor="#989898"
            android:textSize="12sp"/>

        <RadioButton
            android:id="@+id/radioButton2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/selector_checkbox_selector"
            android:button="@null"
            android:background="@null"
            android:tag="2"
            android:text="账号被找回"
            android:textColor="#989898"
            android:textSize="12sp"/>

        <RadioButton
            android:id="@+id/radioButton3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/selector_checkbox_selector"
            android:button="@null"
            android:background="@null"
            android:tag="3"
            android:text="换绑问题"
            android:textColor="#989898"
            android:textSize="12sp"/>

        <RadioButton
            android:id="@+id/radioButton4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/selector_checkbox_selector"
            android:button="@null"
            android:background="@null"
            android:tag="4"
            android:text="账号封禁冻结"
            android:textColor="#989898"
            android:textSize="12sp"/>

        <RadioButton
            android:id="@+id/radioButton5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/selector_checkbox_selector"
            android:button="@null"
            android:background="@null"
            android:tag="5"
            android:text="其他"
            android:textColor="#989898"
            android:textSize="12sp"/>

    </RadioGroup>

    <TextView
        android:id="@+id/tv_submit"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginRight="18dp"
        android:layout_marginLeft="18dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="25dp"
        android:gravity="center"
        android:text="确定"
        android:textColor="#402802"
        android:textSize="14sp"
        android:background="@drawable/shape_radius20_ffd497_fafbf5"/>

</LinearLayout>