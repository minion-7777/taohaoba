<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/page_color">

        <ImageView
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_home_bg"
            android:scaleType="centerCrop"/>

        <io.openim.android.taohaoba.widgets.TitleToolbar
            android:id="@+id/toolbar"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:textTitle="售后详情"/>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/sl_scroll"
            app:layout_constraintTop_toBottomOf="@+id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="10dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="match_parent"
            android:layout_height="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="售后申请已处理完毕"
                    android:textSize="14sp"
                    android:textColor="#EACA92"/>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_after_sales_feedback"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:visibility="visible"
                    android:layout_marginTop="13dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_border_shape">

                    <TextView
                        android:id="@+id/tv_after_sales_feedback"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="售后反馈"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_processing_results_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_after_sales_feedback"
                        android:layout_marginTop="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="处理结果："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_processing_results"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_processing_results_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_compensation_amount_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_processing_results_txt"
                        android:layout_marginTop="15dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="赔付金额："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_compensation_amount"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/tv_compensation_amount_txt"
                        android:layout_marginLeft="10dp"
                        app:layout_constraintTop_toTopOf="@+id/tv_compensation_amount_txt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textColor="#FF4646"
                        android:textSize="12sp"/>

<!--                    <TextView-->
<!--                        android:id="@+id/tv_handling_feedback_txt"-->
<!--                        app:layout_constraintTop_toBottomOf="@+id/tv_compensation_amount_txt"-->
<!--                        android:layout_marginTop="15dp"-->
<!--                        app:layout_constraintStart_toStartOf="parent"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="处理反馈："-->
<!--                        android:textColor="#888888"-->
<!--                        android:textSize="12sp"/>-->

<!--                    <TextView-->
<!--                        android:id="@+id/tv_handling_feedback"-->
<!--                        app:layout_constraintEnd_toEndOf="parent"-->
<!--                        app:layout_constraintTop_toTopOf="@+id/tv_handling_feedback_txt"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="无则显示空白"-->
<!--                        android:textColor="#FFFFFF"-->
<!--                        android:textSize="12sp"/>-->

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:layout_marginTop="13dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_border_shape">

                    <TextView
                        android:id="@+id/tv_after_sales_information"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="售后信息"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_after_sales_type_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_after_sales_information"
                        android:layout_marginTop="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="售后类型："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_after_sales_type"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_after_sales_type_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_mobile_phone_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_after_sales_type_txt"
                        android:layout_marginTop="15dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="联系手机："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_mobile_phone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_mobile_phone_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_contact_weChat_txt"
                        app:layout_constraintTop_toBottomOf="@+id/tv_mobile_phone_txt"
                        android:layout_marginTop="15dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="联系微信："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_contact_weChat"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_contact_weChat_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_application_time_txt"
                        app:layout_constraintTop_toBottomOf="@+id/tv_contact_weChat_txt"
                        android:layout_marginTop="15dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="申请时间："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_application_time"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_application_time_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_processing_time_txt"
                        app:layout_constraintTop_toBottomOf="@+id/tv_application_time_txt"
                        android:layout_marginTop="15dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="处理时间："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_processing_time"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_processing_time_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_completion_time_txt"
                        app:layout_constraintTop_toBottomOf="@+id/tv_processing_time_txt"
                        android:layout_marginTop="15dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="完成时间："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_completion_time"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_completion_time_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_cancel_time_txt"
                        app:layout_constraintTop_toBottomOf="@+id/tv_completion_time_txt"
                        android:layout_marginTop="15dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="取消时间："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_cancel_time"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_cancel_time_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:layout_marginTop="13dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_border_shape">

                    <TextView
                        android:id="@+id/tv_commodity_information"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="商品信息"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_order_number"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_commodity_information"
                        android:layout_marginTop="13dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableRight="@mipmap/ic_copy"
                        android:drawablePadding="10dp"
                        android:text="商品编号："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <io.openim.android.taohaoba.widgets.RoundImageView
                        android:id="@+id/iv_order_goods_img"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_number"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_marginTop="18dp"
                        app:corner_radius="10dp"
                        android:src="@mipmap/ic_me_bg"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/tv_order_goods_name"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/iv_order_goods_img"
                        app:layout_constraintStart_toEndOf="@+id/iv_order_goods_img"
                        android:layout_width="0dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="-2dp"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tv_order_goods_area_code"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_goods_name"
                        app:layout_constraintStart_toEndOf="@+id/iv_order_goods_img"
                        android:layout_width="0dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="8dp"
                        android:layout_height="wrap_content"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_goodsPrice"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_goods_area_code"
                        app:layout_constraintStart_toEndOf="@+id/iv_order_goods_img"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="8dp"
                        android:text="￥0.00"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_price"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_goods_area_code"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginRight="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="8dp"
                        android:text="实付款￥0.00"
                        android:textColor="#FF4646"
                        android:textSize="12sp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:layout_marginTop="13dp"
                    android:layout_marginBottom="20dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_border_shape">

                    <TextView
                        android:id="@+id/tv_order_details"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="订单信息"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_order_number_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_details"
                        android:layout_marginTop="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="订单编号："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_order_number_count"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_order_number_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableRight="@mipmap/ic_copy"
                        android:drawablePadding="10dp"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_transaction_type_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_number_txt"
                        android:layout_marginTop="15dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="交易类型："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_transaction_type"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_transaction_type_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_is_baopei_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_transaction_type_txt"
                        android:layout_marginTop="15dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="是否包赔："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_is_baopei"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_is_baopei_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_order_time_txt"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_is_baopei_txt"
                        android:layout_marginTop="15dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="下单时间："
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_order_time"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_order_time_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"/>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_deal_time"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_time_txt"
                        android:layout_marginTop="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/tv_deal_time_txt"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="成交时间："
                            android:textColor="#888888"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_deal_time"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/tv_deal_time_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
