<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingBottom="34dp"
    android:orientation="vertical"
    android:background="@drawable/shape_radius10_242527">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="19dp"
            android:text="提现"
            android:textColor="#ffffff"
            android:textSize="18sp"/>

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_close"
            android:padding="12dp"
            android:layout_gravity="right"/>

    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:layout_marginLeft="18dp"
        android:text="提现金额"
        android:textColor="#FFFFFF"
        android:textSize="12sp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_marginTop="29dp"
        android:layout_marginRight="18dp"
        android:layout_marginLeft="18dp"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/et_withdraw"
            app:layout_constraintLeft_toRightOf="@+id/tv_test"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@null"
            android:maxLength="9"
            android:hint="输入提现金额"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textColorHint="#696969"
            android:paddingLeft="28dp"/>

        <TextView
            android:id="@+id/tv_withdraw_all"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:gravity="center"
            android:text="全部提现"
            android:textColor="#EACA92"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_test"
            app:layout_constraintTop_toTopOf="@id/et_withdraw"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_marginRight="12dp"
            android:gravity="center"
            android:text="￥"
            android:textColor="#FFFFFF"
            android:textSize="20sp"/>

        <View
            android:layout_width="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="0.5dp"
            android:background="#525357"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="18dp"
        android:text="可提现金额：￥0.00"
        android:textColor="#9C9C9C"
        android:textSize="15sp"/>

    <TextView
        android:id="@+id/tv_submit"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginLeft="38dp"
        android:layout_marginRight="38dp"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="确认提现"
        android:textColor="#402802"
        android:textStyle="bold"
        android:textSize="14sp"
        android:background="@drawable/shape_radius22_5_ffd497_fafbf5"/>

</LinearLayout>