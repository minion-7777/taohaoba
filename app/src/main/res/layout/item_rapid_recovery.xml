<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:paddingLeft="14dp"
    android:paddingRight="14dp"
    android:layout_marginBottom="20dp"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp"
    android:background="@drawable/gradient_border_shape">

    <io.openim.android.taohaoba.widgets.CircleImageView
        android:id="@+id/iv_head"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@mipmap/ic_coll_customer_service"/>

    <TextView
        android:id="@+id/tv_name"
        app:layout_constraintStart_toEndOf="@+id/iv_head"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:textSize="15sp"
        android:textColor="#FFFFFF"/>

    <TextView
        android:id="@+id/tv_tag"
        app:layout_constraintStart_toStartOf="@+id/tv_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:drawableLeft="@mipmap/ic_rapid_recovery_log"
        android:drawablePadding="5dp"
        android:text="诚信卖家"
        android:textSize="11sp"
        android:textColor="#EACA92"/>

    <TextView
        android:id="@+id/tv_but"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        android:layout_marginTop="3dp"
        android:paddingLeft="22dp"
        android:paddingRight="22dp"
        android:gravity="center"
        android:textStyle="bold"
        android:background="@drawable/shape_radius22_5_ffd497_fafbf5"
        android:text="聊一聊"
        android:textSize="15sp"
        android:textColor="#402802"/>


</androidx.constraintlayout.widget.ConstraintLayout>