<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@mipmap/ic_login_bg">

        <ImageView
            android:id="@+id/iv_return"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_return"/>

        <io.openim.android.taohaoba.widgets.RoundImageView
            android:id="@+id/iv_log"
            app:layout_constraintTop_toBottomOf="@+id/iv_return"
            android:layout_width="55dp"
            android:layout_height="55dp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="21dp"
            android:layout_marginLeft="17dp"
            app:corner_radius="20dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"/>

        <TextView
            android:id="@+id/tv_app_name"
            app:layout_constraintTop_toBottomOf="@+id/iv_log"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="18dp"
            android:text="欢迎来到淘号8"
            android:textColor="#FFD497"
            android:textSize="30sp"/>

        <TextView
            android:id="@+id/tv_hint"
            app:layout_constraintTop_toBottomOf="@+id/tv_app_name"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="16dp"
            android:text="未注册手机号验证后自动注册并登录"
            android:textColor="#ABABAB"
            android:textSize="12sp"/>

        <EditText
            android:id="@+id/et_phone"
            app:layout_constraintTop_toBottomOf="@+id/tv_hint"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="25dp"
            android:layout_marginLeft="17dp"
            android:layout_marginRight="17dp"
            android:hint="请输入您的手机号"
            android:textColor="#ABABAB"
            android:textSize="13sp"
            android:textColorHint="#ABABAB"
            android:drawableLeft="@mipmap/ic_phone"
            android:drawablePadding="11dp"
            android:paddingLeft="14dp"
            android:inputType="phone"
            android:maxLength="11"
            android:background="@drawable/gradient_border_shape"/>

        <EditText
            android:id="@+id/et_verification_code"
            app:layout_constraintTop_toBottomOf="@+id/et_phone"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="16dp"
            android:layout_marginLeft="17dp"
            android:layout_marginRight="17dp"
            android:hint="请输入验证码"
            android:textColor="#ABABAB"
            android:textSize="13sp"
            android:textColorHint="#ABABAB"
            android:drawableLeft="@mipmap/ic_pwd"
            android:drawablePadding="11dp"
            android:maxLength="6"
            android:paddingLeft="14dp"
            android:inputType="number"
            android:background="@drawable/gradient_border_shape"/>

        <EditText
            android:id="@+id/et_pwd"
            app:layout_constraintTop_toBottomOf="@+id/et_phone"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="16dp"
            android:layout_marginLeft="17dp"
            android:layout_marginRight="17dp"
            android:visibility="invisible"
            android:hint="请输入您的密码"
            android:textColor="#ABABAB"
            android:textSize="13sp"
            android:textColorHint="#ABABAB"
            android:drawableLeft="@mipmap/ic_pwd"
            android:drawablePadding="11dp"
            android:maxLength="20"
            android:paddingLeft="14dp"
            android:inputType="textPassword"
            android:background="@drawable/gradient_border_shape"/>

        <ImageView
            android:id="@+id/iv_show_pwd"
            app:layout_constraintTop_toTopOf="@+id/et_pwd"
            app:layout_constraintEnd_toEndOf="@+id/et_pwd"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginRight="7dp"
            android:scaleType="centerInside"
            android:visibility="invisible"
            android:src="@mipmap/ic_looks_f"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tv_send"
            app:layout_constraintTop_toTopOf="@+id/et_verification_code"
            app:layout_constraintEnd_toEndOf="@+id/et_verification_code"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_marginRight="12dp"
            android:gravity="center"
            android:text="发送验证码"
            android:textColor="#EACA92"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_pwd_login"
            app:layout_constraintTop_toBottomOf="@+id/et_verification_code"
            app:layout_constraintEnd_toEndOf="@+id/et_verification_code"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:gravity="center"
            android:text="密码登录"
            android:textColor="#EACA92"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_to_login"
            app:layout_constraintTop_toBottomOf="@+id/tv_pwd_login"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginLeft="17dp"
            android:layout_marginRight="17dp"
            android:gravity="center"
            android:text="登录"
            android:textColor="#402802"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius22_5_ffd497_fafbf5"/>

        <LinearLayout
            android:id="@+id/ll_agreement"
            app:layout_constraintTop_toBottomOf="@+id/tv_to_login"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_check"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_check_f"/>

            <TextView
                android:id="@+id/tv_agreement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="7dp"
                android:gravity="center"
                android:text="我已阅读并同意《服务协议》和《隐私协议》"
                android:textColor="#888888"
                android:textSize="14sp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_wechat_login"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="30dp"
            android:visibility="invisible"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="其他登录方式"
                android:textColor="#ABABAB"
                android:textSize="12sp"/>

            <ImageView
                android:id="@+id/iv_wechar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_wechat"/>

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
