<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/page_color">

        <ImageView
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_home_bg"
            android:scaleType="centerCrop"/>

        <io.openim.android.taohaoba.widgets.TitleToolbar
            android:id="@+id/toolbar"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:textTitle="申请售后"/>

        <androidx.core.widget.NestedScrollView
            app:layout_constraintTop_toBottomOf="@+id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="10dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="match_parent"
            android:layout_height="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:layout_marginTop="10dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradient_border_shape">

                    <io.openim.android.taohaoba.widgets.RoundImageView
                        android:id="@+id/iv_order_goods_img"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@mipmap/ic_me_bg"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/iv_order_goods_name"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/iv_order_goods_img"
                        app:layout_constraintStart_toEndOf="@+id/iv_order_goods_img"
                        android:layout_width="0dp"
                        android:maxLines="2"
                        android:minLines="2"
                        android:ellipsize="end"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="-2dp"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tv_order_goods_area_code"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/iv_order_goods_name"
                        app:layout_constraintStart_toEndOf="@+id/iv_order_goods_img"
                        android:layout_width="0dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="7dp"
                        android:layout_height="wrap_content"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_price"
                        app:layout_constraintTop_toBottomOf="@+id/tv_order_goods_area_code"
                        app:layout_constraintStart_toEndOf="@+id/iv_order_goods_img"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="7dp"
                        android:text="￥0.00"
                        android:textColor="#FF4646"
                        android:textSize="18sp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_marginTop="18dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/gradient_border_shape">

                    <TextView
                        android:id="@+id/tv_txtb"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="联系方式"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_txta"
                        app:layout_constraintTop_toBottomOf="@+id/tv_txtb"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_txt_lxfs"
                        app:layout_constraintTop_toTopOf="@+id/tv_txta"
                        app:layout_constraintStart_toEndOf="@+id/tv_txta"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="手机号码"
                        android:textColor="#898A8B"
                        android:textSize="15sp"/>

                    <EditText
                        android:id="@+id/tv_phone"
                        app:layout_constraintTop_toTopOf="@+id/tv_txt_lxfs"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:gravity="center_vertical|end"
                        android:background="@null"
                        android:paddingRight="16dp"
                        android:maxLength="11"
                        android:inputType="number"
                        android:hint="请输入手机号码"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#626262"
                        android:textSize="15sp"/>

                    <View
                        android:id="@+id/view"
                        app:layout_constraintTop_toBottomOf="@+id/tv_txt_lxfs"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#393B3D"/>

                    <TextView
                        android:id="@+id/tv_txt_wx"
                        app:layout_constraintTop_toBottomOf="@+id/view"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="\t微信"
                        android:textColor="#898A8B"
                        android:textSize="15sp"/>

                    <EditText
                        android:id="@+id/tv_wechat_number"
                        app:layout_constraintTop_toTopOf="@+id/tv_txt_wx"
                        app:layout_constraintStart_toEndOf="@+id/tv_txt_wx"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginLeft="10dp"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:gravity="center_vertical|end"
                        android:background="@null"
                        android:paddingRight="16dp"
                        android:maxLength="15"
                        android:hint="请输入微信号"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#626262"
                        android:textSize="15sp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_marginTop="18dp"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/gradient_border_shape">

                    <TextView
                        android:id="@+id/tv_txtc"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_txtd"
                        app:layout_constraintStart_toEndOf="@+id/tv_txtc"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="申请说明"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <EditText
                        android:id="@+id/tv_specific_situation"
                        app:layout_constraintTop_toBottomOf="@+id/tv_txtd"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:padding="10dp"
                        android:gravity="left"
                        android:maxLength="200"
                        android:background="@drawable/shape_radius10_323335"
                        android:minLines="4"
                        android:hint="请您详细描述具体情况。(不超过200字)"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#626262"
                        android:textSize="15sp"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_marginTop="18dp"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="@drawable/gradient_border_shape">

                    <TextView
                        android:id="@+id/tv_txtf"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="截图证明"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_txtg"
                        app:layout_constraintTop_toBottomOf="@+id/tv_txtf"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="请上传相关截图，以便客服快速了解情况。"
                        android:textColor="#626262"
                        android:textSize="11sp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rc_recycler"
                        app:layout_constraintTop_toBottomOf="@+id/tv_txtg"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_upload_img"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/tv_submit"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="22dp"
                    android:layout_marginLeft="25dp"
                    android:layout_marginRight="25dp"
                    android:gravity="center"
                    android:text="提交"
                    android:textColor="#402802"
                    android:textSize="14sp"
                    android:background="@drawable/shape_radius18_ffd497_fafbf5"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
