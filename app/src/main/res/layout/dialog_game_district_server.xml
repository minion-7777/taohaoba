<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:layout_marginTop="150dp"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <androidx.core.widget.NestedScrollView
        android:layout_above="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_semicircle_radius10_242527">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center_horizontal"
                    android:text="选择区服"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"/>

                <ImageView
                    android:id="@+id/iv_close"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:padding="12dp"
                    android:layout_gravity="right|center_vertical"
                    android:src="@mipmap/ic_dialog_close"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tv_yxlx"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:layout_marginLeft="16dp"
                android:visibility="gone"
                android:text="游戏类型"
                android:textSize="18sp"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tv_game_type_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="16dp"
                android:visibility="gone"
                android:textSize="15sp"
                android:gravity="center"
                android:textColor="@color/color_402802"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingLeft="30dp"
                android:paddingRight="30dp"
                android:background="@drawable/shape_radius15_eaca92"/>

            <TextView
                android:id="@+id/tv_sb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="16dp"
                android:text="设备"
                android:textSize="18sp"
                android:textColor="#FFFFFF"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rc_recycler1"
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tv_yxqf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="16dp"
                android:visibility="gone"
                android:text="区服分类"
                android:textSize="18sp"
                android:textColor="#FFFFFF"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rc_recycler2"
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/ll_yxqf2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginLeft="16dp"
                    android:text="服务器"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rc_recycler4"
                    android:layout_marginTop="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_yys"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginLeft="16dp"
                android:visibility="gone"
                android:text="运营商"
                android:textSize="18sp"
                android:textColor="#FFFFFF"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rc_recycler3"
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_above="@+id/ll_bottom"
        android:layout_height="0.5dp"
        android:background="#4A4A4A"/>

    <LinearLayout
        android:id="@+id/ll_bottom"
        android:layout_alignParentBottom="true"
        android:background="#242527"
        android:paddingLeft="56dp"
        android:paddingRight="56dp"
        android:paddingTop="17dp"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_cancel"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginRight="20dp"
            android:gravity="center"
            android:text="重置"
            android:textColor="#888888"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_line_b9b9b9"/>

        <TextView
            android:id="@+id/tv_submit"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginLeft="20dp"
            android:gravity="center"
            android:text="确认"
            android:textColor="#402802"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_ffd497_fafbf5"/>

    </LinearLayout>

</RelativeLayout>