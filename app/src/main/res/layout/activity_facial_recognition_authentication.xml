<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/page_color">

        <ImageView
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_home_bg"
            android:scaleType="centerCrop"/>

        <RelativeLayout
            android:id="@+id/rl_title"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:src="@mipmap/ic_back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="刷脸认证"
                android:textColor="#ffffff"
                android:textSize="17sp"/>
        </RelativeLayout>

        <ImageView
            android:id="@+id/iv_portrait"
            app:layout_constraintTop_toBottomOf="@+id/rl_title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="60dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:src="@mipmap/ic_face_swiping"
            android:paddingTop="62dp"
            android:paddingBottom="62dp"
            android:background="@drawable/gradient_border_shape"/>

        <ImageView
            android:id="@+id/iv_select"
            app:layout_constraintTop_toBottomOf="@+id/iv_portrait"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="19dp"
            android:layout_marginLeft="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_select_t"/>

        <TextView
            android:id="@+id/tv_agreement1"
            app:layout_constraintTop_toTopOf="@+id/iv_select"
            app:layout_constraintStart_toEndOf="@+id/iv_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="同意《认证服务协议》"
            android:textColor="#888888"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/tv_agreement2"
            app:layout_constraintStart_toStartOf="@+id/tv_agreement1"
            app:layout_constraintTop_toBottomOf="@+id/tv_agreement1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="同意认证后，将获取您的摄像头权限用于人脸识别验证身份"
            android:textColor="#626262"
            android:textSize="10sp"/>

        <LinearLayout
            app:layout_constraintTop_toBottomOf="@+id/tv_agreement2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginRight="18dp"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="57dp"
            android:layout_marginBottom="56dp"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tv_cancel"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginRight="8dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="暂不认证"
                android:textColor="#FDE1B7"
                android:textSize="14sp"
                android:background="@drawable/shape_radius20_363739"/>

            <TextView
                android:id="@+id/tv_submit"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="开始认证"
                android:textColor="#402802"
                android:textSize="14sp"
                android:background="@drawable/shape_radius20_ffd497_fafbf5"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
