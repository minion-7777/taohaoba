<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/page_color"
        android:fitsSystemWindows="true">

        <ImageView
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_home_bg"
            android:scaleType="centerCrop"/>

        <io.openim.android.taohaoba.widgets.TitleToolbar
            android:id="@+id/toolbar"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:id="@+id/ll_bottom"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right"
            android:padding="12dp"
            android:background="#222222"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_submit"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                android:paddingLeft="27dp"
                android:paddingRight="27dp"
                android:gravity="center"
                android:text="提交"
                android:textColor="#402802"
                android:textSize="14sp"
                android:background="@drawable/shape_radius18_ffd497_fafbf5"/>

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/sl_scroll"
            app:layout_constraintBottom_toTopOf="@+id/ll_bottom"
            app:layout_constraintTop_toBottomOf="@+id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="10dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="match_parent"
            android:layout_height="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_border_shape"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clzhly"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <TextView
                        android:id="@+id/tv_text1"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_text2"
                        app:layout_constraintStart_toEndOf="@+id/tv_text1"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="账号来源"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/radioGroup1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/radioButton1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@drawable/selector_checkbox_selector"
                            android:button="@null"
                            android:checked="true"
                            android:drawablePadding="5dp"
                            android:tag="1"
                            android:text="个人注册"
                            android:textColor="#989898"
                            android:textSize="12sp"/>

                        <RadioButton
                            android:id="@+id/radioButton2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@drawable/selector_checkbox_selector"
                            android:button="@null"
                            android:drawablePadding="5dp"
                            android:layout_marginStart="12dp"
                            android:tag="2"
                            android:text="本平台购买"
                            android:textColor="#989898"
                            android:textSize="12sp"/>

                        <RadioButton
                            android:id="@+id/radioButton3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@drawable/selector_checkbox_selector"
                            android:button="@null"
                            android:drawablePadding="5dp"
                            android:layout_marginStart="12dp"
                            android:tag="3"
                            android:text="其他"
                            android:textColor="#989898"
                            android:textSize="12sp"/>

                    </RadioGroup>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clecsm"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <TextView
                        android:id="@+id/tv_text3"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_text4"
                        app:layout_constraintStart_toEndOf="@+id/tv_text3"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="二次实名"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/radioGroup2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/radioButton4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@drawable/selector_checkbox_selector"
                            android:button="@null"
                            android:checked="true"
                            android:drawablePadding="5dp"
                            android:tag="1"
                            android:text="可改实名"
                            android:textColor="#989898"
                            android:textSize="12sp"/>

                        <RadioButton
                            android:id="@+id/radioButton5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@drawable/selector_checkbox_selector"
                            android:button="@null"
                            android:drawablePadding="5dp"
                            android:layout_marginStart="12dp"
                            android:tag="0"
                            android:text="不可改实名"
                            android:textColor="#989898"
                            android:textSize="12sp"/>

                    </RadioGroup>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clfcm"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <TextView
                        android:id="@+id/tv_text5"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_text6"
                        app:layout_constraintStart_toEndOf="@+id/tv_text5"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="防沉迷"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <RadioGroup
                        android:id="@+id/radioGroup3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/radioButton6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@drawable/selector_checkbox_selector"
                            android:button="@null"
                            android:checked="true"
                            android:drawablePadding="5dp"
                            android:tag="1"
                            android:text="有防沉迷"
                            android:textColor="#989898"
                            android:textSize="12sp"/>

                        <RadioButton
                            android:id="@+id/radioButton7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@drawable/selector_checkbox_selector"
                            android:button="@null"
                            android:drawablePadding="5dp"
                            android:layout_marginStart="12dp"
                            android:tag="0"
                            android:text="无防沉迷"
                            android:textColor="#989898"
                            android:textSize="12sp"/>

                    </RadioGroup>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <TextView
                        android:id="@+id/tv_text7"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_text8"
                        app:layout_constraintStart_toEndOf="@+id/tv_text7"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="联系方式"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <EditText
                        android:id="@+id/et_count"
                        app:layout_constraintStart_toEndOf="@+id/tv_text8"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="10dp"
                        android:background="@null"
                        android:imeOptions="actionNext"
                        android:singleLine="true"
                        android:hint="请输入联系方式"
                        android:textColor="#FFFFFF"
                        android:inputType="phone"
                        android:gravity="right|center_vertical"
                        android:textColorHint="#626262"
                        android:textSize="13sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <TextView
                        android:id="@+id/tv_text12"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:visibility="invisible"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_text13"
                        app:layout_constraintStart_toEndOf="@+id/tv_text12"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="商品亮点"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <EditText
                        android:id="@+id/et_sparkle"
                        android:layout_width="0dp"
                        app:layout_constraintStart_toEndOf="@+id/tv_text13"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:imeOptions="actionNext"
                        android:layout_marginLeft="10dp"
                        android:singleLine="true"
                        android:hint="请输入商品亮点"
                        android:textColor="#FFFFFF"
                        android:gravity="right|center_vertical"
                        android:textColorHint="#626262"
                        android:textSize="13sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:visibility="gone"
                    android:layout_height="50dp">

                    <TextView
                        android:id="@+id/tv_text9"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="*"
                        android:textColor="#FF4646"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_text10"
                        app:layout_constraintStart_toEndOf="@+id/tv_text9"
                        app:layout_constraintTop_toTopOf="parent"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="商品标签"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_label"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="请选择"
                        android:textColor="#FFFFFF"
                        android:gravity="right|center_vertical"
                        android:drawableRight="@mipmap/ic_jt"
                        android:drawablePadding="9dp"
                        android:textColorHint="#626262"
                        android:textSize="13sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rc_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_game_configuration_one"/>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
