<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/gradient_border_shape"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:textColor="#D6D6D6"
                    android:gravity="center"
                    android:text="游戏名称"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

                <View
                    android:layout_width="0.5dp"
                    android:layout_height="match_parent"
                    android:background="#404143"/>

                <TextView
                    android:id="@+id/tv_name1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#404143"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:textColor="#D6D6D6"
                    android:gravity="center"
                    android:text="商品编号"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

                <View
                    android:layout_width="0.5dp"
                    android:layout_height="match_parent"
                    android:background="#404143"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:id="@+id/tv_name2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888888"
                        android:layout_gravity="center"
                        android:textSize="12sp"
                        android:drawableRight="@mipmap/ic_copy"
                        android:drawablePadding="10dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"/>
                </FrameLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#404143"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:textColor="#D6D6D6"
                    android:gravity="center"
                    android:text="商品类型"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

                <View
                    android:layout_width="0.5dp"
                    android:layout_height="match_parent"
                    android:background="#404143"/>

                <TextView
                    android:id="@+id/tv_name3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#404143"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:textColor="#D6D6D6"
                    android:gravity="center"
                    android:text="发布时间"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

                <View
                    android:layout_width="0.5dp"
                    android:layout_height="match_parent"
                    android:background="#404143"/>

                <TextView
                    android:id="@+id/tv_name4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/clecsm"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#404143"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.5"
                        android:textColor="#D6D6D6"
                        android:gravity="center"
                        android:text="实名情况"
                        android:textSize="12sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"/>

                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="match_parent"
                        android:background="#404143"/>

                    <TextView
                        android:id="@+id/tv_name5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"/>

                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:id="@+id/clfcm"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#404143"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.5"
                        android:textColor="#D6D6D6"
                        android:gravity="center"
                        android:text="有无防沉迷"
                        android:textSize="12sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"/>

                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="match_parent"
                        android:background="#404143"/>

                    <TextView
                        android:id="@+id/tv_name6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/clzhly"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#404143"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.5"
                        android:textColor="#D6D6D6"
                        android:gravity="center"
                        android:text="账号来源"
                        android:textSize="12sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"/>

                    <View
                        android:layout_width="0.5dp"
                        android:layout_height="match_parent"
                        android:background="#404143"/>

                    <TextView
                        android:id="@+id/tv_name7"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#888888"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rc_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/gradient_border_shape"
            tools:listitem="@layout/item_product_description"/>

    </LinearLayout>
</layout>
