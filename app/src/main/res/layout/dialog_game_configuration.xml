<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="bottom"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="250dp"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/view"
        android:background="@drawable/shape_semicircle_radius10_242527">

        <TextView
            android:id="@+id/tv_title"
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="17dp"
            android:textSize="18sp"
            android:textColor="#FFFFFF"/>

        <FrameLayout
            android:id="@+id/fl_search"
            android:layout_below="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:layout_height="35dp"
            android:background="@drawable/shape_radius18_3c3c3c">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:drawableLeft="@mipmap/ic_search"
                android:layout_marginLeft="12dp"
                android:drawablePadding="10dp"
                android:maxLength="15"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:hint="请输入"
                android:textColorHint="#7B7B7B"
                android:background="@null"
                android:textColor="#7B7B7B"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_search"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:background="@drawable/shape_radius15_feeba7"
                android:paddingLeft="23dp"
                android:paddingRight="23dp"
                android:gravity="center"
                android:layout_gravity="center_vertical|right"
                android:text="搜索"
                android:textColor="#402802"
                android:textSize="13sp"/>

        </FrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rc_recycler"
            android:layout_below="@+id/fl_search"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            tools:listitem="@layout/item_game_configuration"/>

    </RelativeLayout>

    <View
        android:id="@+id/view"
        android:layout_above="@+id/ll_bottom"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#4A4A4A"/>

    <LinearLayout
        android:id="@+id/ll_bottom"
        android:layout_alignParentBottom="true"
        android:background="#242527"
        android:paddingLeft="56dp"
        android:paddingRight="56dp"
        android:paddingTop="17dp"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_cancel"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginRight="20dp"
            android:gravity="center"
            android:text="取消"
            android:textColor="#888888"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_line_b9b9b9"/>

        <TextView
            android:id="@+id/tv_submit"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:layout_marginLeft="20dp"
            android:gravity="center"
            android:text="确认"
            android:textColor="#402802"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_ffd497_fafbf5"/>

    </LinearLayout>


</RelativeLayout>