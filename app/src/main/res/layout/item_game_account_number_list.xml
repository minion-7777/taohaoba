<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:padding="12dp"
    android:layout_marginBottom="10dp"
    android:orientation="horizontal"
    android:background="@drawable/gradient_border_shape"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <io.openim.android.taohaoba.widgets.RoundImageView
        android:id="@+id/iv_img"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@mipmap/ic_me_bg"
        app:corner_radius="10dp"
        android:scaleType="centerCrop"/>

   <LinearLayout
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:layout_marginLeft="11dp"
       android:orientation="vertical">

       <TextView
           android:id="@+id/tv_hint"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:maxLines="2"
           android:ellipsize="end"
           android:textColor="#FFFFFF"
           android:textSize="14sp"/>

       <androidx.recyclerview.widget.RecyclerView
           android:id="@+id/rc_recycler"
           app:layout_constraintTop_toBottomOf="@+id/iv_img"
           app:layout_constraintStart_toStartOf="parent"
           android:layout_marginTop="8dp"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           tools:listitem="@layout/item_tag"
           tools:itemCount="2"/>

       <TextView
           android:id="@+id/tv_service_name"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:layout_marginTop="8dp"
           android:textColor="#888888"
           android:textSize="12sp"/>

       <androidx.constraintlayout.widget.ConstraintLayout
           android:layout_marginTop="8dp"
           android:layout_width="match_parent"
           android:layout_height="wrap_content">

           <TextView
               android:id="@+id/tv_view_count"
               app:layout_constraintEnd_toStartOf="@+id/tv_give_up"
               app:layout_constraintTop_toTopOf="parent"
               app:layout_constraintBottom_toBottomOf="parent"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_marginEnd="12dp"
               android:layout_marginStart="5dp"
               android:drawableLeft="@mipmap/ic_view_f"
               android:drawablePadding="5dp"
               android:text="0"
               android:textColor="#969696"
               android:textSize="11sp"/>

           <TextView
               android:id="@+id/tv_give_up"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent"
               app:layout_constraintBottom_toBottomOf="parent"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:drawableLeft="@mipmap/ic_give_up_f"
               android:drawablePadding="5dp"
               android:text="0"
               android:textColor="#969696"
               android:textSize="11sp"/>

           <TextView
               android:id="@+id/tv_price"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="￥0.00"
               android:textColor="#FF4646"
               android:textSize="18sp"/>

       </androidx.constraintlayout.widget.ConstraintLayout>

   </LinearLayout>

</LinearLayout>