<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>

    </data>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/page_color">

        <ImageView
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_home_bg"
            android:scaleType="centerCrop"/>

        <io.openim.android.taohaoba.widgets.TitleToolbar
            android:id="@+id/toolbar"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_warn"
            app:layout_constraintTop_toBottomOf="@+id/toolbar"
            android:background="#33EACA92"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="以下号商均已缴纳高额保证金，请放心交易"
            android:textColor="#EACA92"
            android:textSize="12sp"
            android:drawableStart="@mipmap/ic_rapid_recovery_tag"
            android:drawablePadding="5dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rc_recycler"
            app:layout_constraintTop_toBottomOf="@+id/tv_warn"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingTop="25dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            tools:listitem="@layout/item_rapid_recovery"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
