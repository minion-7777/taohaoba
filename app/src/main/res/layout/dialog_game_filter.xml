<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="100dp"
    android:background="@drawable/shape_semicircle_radius10_201d19">

    <FrameLayout
        android:id="@+id/fl_top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="match_parent"
        android:layout_height="50dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="筛选"
            android:textColor="#ffffff"
            android:textSize="18sp"/>

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_close"
            android:padding="15dp"
            android:layout_gravity="right|center_vertical"/>

    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_recycler1"
        app:layout_constraintTop_toBottomOf="@+id/fl_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/ll_bottom"
        android:layout_width="98dp"
        android:background="#3C3C3C"
        android:layout_height="0dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc_recycler2"
        app:layout_constraintStart_toEndOf="@+id/rc_recycler1"
        app:layout_constraintTop_toBottomOf="@+id/fl_top"
        app:layout_constraintBottom_toTopOf="@+id/ll_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="0dp"
        android:layout_height="0dp"/>

    <LinearLayout
        android:id="@+id/ll_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="12dp"
        android:background="#201D19"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_cancel"
            android:layout_width="136dp"
            android:layout_height="35dp"
            android:gravity="center"
            android:text="重置"
            android:textColor="#888888"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_line_b9b9b9"/>

        <TextView
            android:id="@+id/tv_submit"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:layout_marginLeft="17dp"
            android:gravity="center"
            android:text="查看"
            android:textColor="#402802"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/shape_radius18_ffd497_fafbf5"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>