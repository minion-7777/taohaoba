<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. 渐变边框（模拟） -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#1E1E1E"
                android:endColor="#A7A7A7"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- 2. 背景色（覆盖中间部分） -->
    <item android:left="0.5dp" android:top="0.5dp" android:right="0.5dp" android:bottom="0.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#2F3032" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>